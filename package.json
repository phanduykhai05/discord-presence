{
  "name": "vibecoder-discord-presence",
  "version": "1.1.0",
  "description": "Show your Claude Code activity on Discord as Rich Presence — privacy-first and themeable.",
  "type": "module",
  "bin": {
    "vdp": "dist/vdp.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/vdp.ts",
    "start": "node dist/vdp.js",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "discord",
    "rich-presence",
    "claude-code",
    "claude",
    "cli",
    "presence",
    "vibecoder"
  ],
  "license": "MIT",
  "author": "Younesfdj",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/younesfdj/vibecoder-discord-presence.git"
  },
  "homepage": "https://github.com/younesfdj/vibecoder-discord-presence#readme",
  "bugs": "https://github.com/younesfdj/vibecoder-discord-presence/issues",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@xhayper/discord-rpc": "^1.3.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
